{
  "name": "@cucumber/cucumber-json-converter",
  "version": "0.1.0",
  "description": "Validates and converts Cucumber JSON for different Cucumber implementations and versions",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "mocha",
    "prepublishOnly": "npm run build",
    "fix": "biome check --fix --error-on-warnings",
    "lint": "biome check --error-on-warnings"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/cucumber/cucumber-json-converter.git"
  },
  "keywords": [
    "cucumber",
    "steps",
    "regexp",
    "regex"
  ],
  "author": "Cucumber Limited <cukes@googlegroups.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cucumber/cucumber-json-converter/issues"
  },
  "homepage": "https://github.com/cucumber/cucumber-json-converter#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@cucumber/biome-config": "github:cucumber/biome-config#v0.2.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/glob": "9.0.0",
    "@types/mocha": "10.0.10",
    "@types/node": "22.19.20",
    "glob": "13.0.6",
    "mocha": "11.7.6",
    "pretty-quick": "4.2.2",
    "ts-json-schema-generator": "2.9.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@cucumber/json-schema": "^0.2.0",
    "ajv": "8.20.0"
  },
  "directories": {
    "test": "test"
  }
}
